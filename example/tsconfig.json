{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "ustro": ["../src/index.ts"],
      "ustro/control": ["../src/control/index.ts"],
      "ustro/core": ["../src/core/index.ts"],
      "ustro/reactive": ["../src/reactive/index.ts"],
      "ustro/html": ["../src/html/index.ts"],
      "ustro/modifiers": ["../src/modifiers/index.ts"],
      "ustro/navigator": ["../src/navigator/index.ts"],
      "ustro/svg": ["../src/svg/index.ts"],
      "ustro/unit": ["../src/unit/index.ts"],
      "ustro/validator": ["../src/validator/index.ts"],
    },
    "experimentalDecorators": true,
  },
  "include": ["src", "vite.config.ts"],
}
